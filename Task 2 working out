#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

#include "ch.h"
#include "hal.h"
#include "memory_protection.h"
#include <main.h>
#include "leds.h"
#include "spi_comm.h"
#include "sensors/proximity.h"
#include "motors.h"
#include "epuck1x/uart/e_uart_char.h"
#include "serial_comm.h"

messagebus_t bus;
MUTEX_DECL(bus_lock);
CONDVAR_DECL(bus_condvar);


int main(void)
{

	int threshold = 800;

    halInit();
    chSysInit();
    mpu_init();

    // Proximity
    messagebus_init(&bus, &bus_lock, &bus_condvar);
    proximity_start(0);
    calibrate_ir();

    //LED
    clear_leds();
    spi_comm_start();

    //Motors
    motors_init();

    //Bluetooth
    serial_start();
	
    /* Infinite loop. */
    while (1)
    {
		int sensorvalues = {0,0,0,0,0,0,0,0}
		int maxvalues = {0,0}
		for (int i=0; i < 8; i++){
			sensorvalues[i] = get_calibrated_prox(i);
		}	
		for (int i=0: i < 8; i++){
			if (sensorvalues[i] > maxvalues[0]){
				maxvalues[0] = sensorvalues[i]
			}
		for (int i=0: i < 8; i++){
			if (sensorvalues[i] > maxvalues[1] && sensorvalues[i] < maxvalues[0]){
				maxvalues[1] = sensorvalues[i]
			}	
		}
    	
		int leftSensors  = ps6 + ps5 + ps7;
    	int rightSensors = ps1 + ps2 + ps0;

    	int base_speed = 200;
    	int gain = 1;

    	int left_motor  = base_speed + gain * rightSensors;
    	int right_motor = base_speed + gain * leftSensors;
    	if(ps0 > 800 || ps7 > 800)
    	{
    		left_motor_set_speed(-right_motor);
    		right_motor_set_speed(-left_motor);
    	}
    	else if ((400 < ps0 && ps0 < 800) || (400 < ps7 && ps7 < 800))
    		{
    		left_motor_set_speed(0);
    		right_motor_set_speed(0);
    		}
    	else
    	{
			left_motor_set_speed(left_motor);
			right_motor_set_speed(right_motor);
    	}
}

}
#define STACK_CHK_GUARD 0xe2dee396
uintptr_t __stack_chk_guard = STACK_CHK_GUARD;

void __stack_chk_fail(void)
{
    chSysHalt("Stack smashing detected");
}
